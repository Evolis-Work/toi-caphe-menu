---
import AdminCrudPage from "../components/admin/AdminCrudPage";
import MainLayout from "../layouts/MainLayout.astro";

const sheetJsonUrl = import.meta.env.SHEET_JSON_URL ?? "https://script.google.com/macros/s/REPLACE_WITH_YOUR_DEPLOYED_APP_SCRIPT_ID/exec";
---

<MainLayout
  title="Admin | Lộc Cà Phê"
  description="Trang quản trị menu Lộc Cà Phê để thêm, sửa, xoá category và món qua Google Sheet."
  canonicalUrl={Astro.url.href}
>
  <Fragment slot="head">
    <meta name="robots" content="noindex,nofollow,noarchive" />
  </Fragment>

  <AdminCrudPage sheetJsonUrl={sheetJsonUrl} client:load />
</MainLayout>
