---
import MainLayout from "../layouts/MainLayout.astro";

const sheetJsonUrl = import.meta.env.SHEET_JSON_URL || "https://script.google.com/macros/s/REPLACE_WITH_YOUR_DEPLOYED_APP_SCRIPT_ID/exec";
const adminUrl = `${sheetJsonUrl.split("#")[0]}${sheetJsonUrl.includes("?") ? "&" : "?"}view=admin`;
---

<MainLayout
  title="Admin | Lộc Cà Phê"
  description="Mở trang quản trị Google Sheets trong Apps Script HTML Service."
  canonicalUrl={Astro.url.href}
>
  <Fragment slot="head">
    <meta name="robots" content="noindex,nofollow,noarchive" />
  </Fragment>

  <section class="min-h-[70vh] flex items-center justify-center px-6 py-16">
    <div class="max-w-xl w-full text-center space-y-6">
      <p class="text-[10px] uppercase tracking-[0.4em] text-luxury-accent">Admin Launcher</p>
      <h1 class="font-bebas text-5xl uppercase tracking-wide text-white">Mở trang quản trị</h1>
      <p class="text-sm text-luxury-muted/80 leading-relaxed">
        CRUD category và menu item đã được chuyển vào Apps Script HTML Service để tránh lỗi fetch cross-origin.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-3">
        <a
          class="px-5 py-3 rounded-sm border border-luxury-border/20 text-sm uppercase tracking-[0.2em] text-luxury-text hover:border-luxury-accent hover:text-luxury-accent transition-colors"
          href={adminUrl}
          target="_blank"
          rel="noreferrer"
        >
          Open Apps Script Admin
        </a>
        <a
          class="px-5 py-3 rounded-sm bg-luxury-accent text-black text-sm uppercase tracking-[0.2em]"
          href="/"
        >
          Quay lại menu
        </a>
      </div>
      <div class="text-xs text-luxury-muted/60 break-all">
        Admin URL: <span class="text-luxury-text">{adminUrl}</span>
      </div>
    </div>
  </section>
</MainLayout>
