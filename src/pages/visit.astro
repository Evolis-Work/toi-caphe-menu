---
import VisitPage from "../components/Visit/VisitPage";
import "../styles/global.css";

const baseUrl = import.meta.env.BASE_URL;
const withBase = (path: string): string => `${baseUrl.replace(/\/?$/, "/")}${path.replace(/^\//, "")}`;
const faviconUrl = withBase("favicon.svg");
const ogImageUrl = withBase("og-menu.svg");
---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Ghé thăm T.Ô.I COFFEE & TEA</title>
    <meta name="description" content="Thông tin địa chỉ và bản đồ dẫn đường đến T.Ô.I COFFEE & TEA - Bạc Liêu" />
    <meta property="og:title" content="Ghé thăm T.Ô.I COFFEE & TEA" />
    <meta property="og:description" content="Thông tin địa chỉ và bản đồ dẫn đường đến T.Ô.I COFFEE & TEA - Bạc Liêu" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImageUrl} />
    <link rel="icon" href={faviconUrl} type="image/svg+xml" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Oswald:wght@300;400;500;600;700&family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600;1,700&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=block"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen flex flex-col overflow-x-hidden">
    <VisitPage baseUrl={baseUrl} client:load />
  </body>
</html>
