---
import VisitPage from "../components/visit/VisitPage";
import "../styles/global.css";

const baseUrl = import.meta.env.BASE_URL;
const withBase = (path: string): string => `${baseUrl.replace(/\/?$/, "/")}${path.replace(/^\//, "")}`;
const faviconUrl = withBase("favicon.svg");
const ogImageUrl = withBase("og-menu.svg");

const siteUrl = Astro.site?.toString() ?? "https://evolis-work.github.io";
const canonicalUrl = new URL(withBase("visit"), siteUrl).toString();
const ogImageAbsoluteUrl = new URL(ogImageUrl, siteUrl).toString();
const mapUrl = "https://maps.app.goo.gl/aKEMj32fUoLTsR9s8";
const businessTelephone = import.meta.env.PUBLIC_BUSINESS_TELEPHONE ?? import.meta.env.BUSINESS_TELEPHONE ?? "0848882852";
const businessPostalCode = import.meta.env.PUBLIC_BUSINESS_POSTAL_CODE ?? import.meta.env.BUSINESS_POSTAL_CODE ?? "97600";
const businessPriceRange = import.meta.env.PUBLIC_BUSINESS_PRICE_RANGE ?? "$";

const structuredData = {
  "@context": "https://schema.org",
  "@type": "CafeOrCoffeeShop",
  name: "T.Ô.I COFFEE & TEA",
  url: canonicalUrl,
  image: ogImageAbsoluteUrl,
  hasMap: mapUrl,
  sameAs: [mapUrl],
  address: {
    "@type": "PostalAddress",
    streetAddress: "2CJC+V6R, Ấp 4, Đông Hải",
    addressLocality: "Bạc Liêu",
    ...(businessPostalCode ? { postalCode: businessPostalCode } : {}),
    addressCountry: "VN",
  },
  priceRange: businessPriceRange,
  ...(businessTelephone ? { telephone: businessTelephone } : {}),
  inLanguage: "vi",
};
---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />

    <title>Địa Chỉ T.Ô.I COFFEE & TEA | Gành Hào, Bạc Liêu</title>
    <meta
      name="description"
      content="Xem địa chỉ T.Ô.I COFFEE & TEA tại 2CJC+V6R, Ấp 4, Đông Hải, Bạc Liêu và mở Google Maps để chỉ đường nhanh."
    />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="vi_VN" />
    <meta property="og:site_name" content="T.Ô.I COFFEE & TEA" />
    <meta property="og:title" content="Địa Chỉ T.Ô.I COFFEE & TEA | Gành Hào, Bạc Liêu" />
    <meta
      property="og:description"
      content="Thông tin địa chỉ, giờ mở cửa và bản đồ chỉ đường đến T.Ô.I COFFEE & TEA."
    />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageAbsoluteUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Địa Chỉ T.Ô.I COFFEE & TEA | Gành Hào, Bạc Liêu" />
    <meta name="twitter:description" content="Mở Google Maps để đến T.Ô.I COFFEE & TEA nhanh nhất." />
    <meta name="twitter:image" content={ogImageAbsoluteUrl} />

    <meta name="theme-color" content="#0d0d0d" />
    <link rel="icon" href={faviconUrl} type="image/svg+xml" />

    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Oswald:wght@300;400;500;600;700&family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600;1,700&family=Inter:wght@300;400;500;600&display=swap"
      media="print" onload="this.media='all'" rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=block"
      media="print" onload="this.media='all'" rel="stylesheet"
    />
  </head>
  <body class="min-h-screen flex flex-col overflow-x-hidden">
    <VisitPage baseUrl={baseUrl} client:load />
  </body>
</html>
