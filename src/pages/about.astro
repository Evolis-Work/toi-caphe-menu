---
import LuxuryStaticLayout from "../layouts/LuxuryStaticLayout.astro";

const baseUrl = import.meta.env.BASE_URL;
const withBase = (path: string): string => `${baseUrl.replace(/\/?$/, "/")}${path.replace(/^\//, "")}`;
const ogImageUrl = withBase("og-menu.svg");

const siteUrl = Astro.site?.toString() ?? "https://evolis-work.github.io";
const canonicalUrl = new URL(withBase("about"), siteUrl).toString();
const ogImageAbsoluteUrl = new URL(ogImageUrl, siteUrl).toString();
const mapUrl = "https://maps.app.goo.gl/aKEMj32fUoLTsR9s8";

const title = "Giới Thiệu T.Ô.I COFFEE & TEA | Quán Cà Phê Gành Hào";
const description = "Tìm hiểu câu chuyện thương hiệu T.Ô.I COFFEE & TEA tại Gành Hào, Đông Hải, Bạc Liêu và triết lý phục vụ của quán.";

const structuredData = {
  "@context": "https://schema.org",
  "@type": "CafeOrCoffeeShop",
  name: "T.Ô.I COFFEE & TEA",
  url: canonicalUrl,
  image: ogImageAbsoluteUrl,
  hasMap: mapUrl,
  sameAs: [mapUrl],
  address: {
    "@type": "PostalAddress",
    streetAddress: "2CJC+V6R, Ấp 4, Đông Hải",
    addressLocality: "Bạc Liêu",
    addressCountry: "VN",
  },
  inLanguage: "vi",
};
---

<LuxuryStaticLayout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  ogImageAbsoluteUrl={ogImageAbsoluteUrl}
  structuredData={structuredData}
>
  <header class="space-y-3 border-b border-luxury-border/20 pb-6">
    <h1 class="font-bebas text-4xl tracking-[0.08em] text-white uppercase">Về <span class="text-luxury-accent">T.Ô.I COFFEE & TEA</span></h1>
    <p class="font-cormorant italic text-luxury-muted text-lg">Nơi hương vị cà phê và trà được phục vụ với sự chỉn chu mỗi ngày.</p>
  </header>

  <section class="space-y-4">
    <h2 class="font-bebas text-xl tracking-[0.2em] text-luxury-accent uppercase">Câu chuyện</h2>
    <p class="text-sm leading-7 text-luxury-muted/90">T.Ô.I COFFEE & TEA được xây dựng với mục tiêu mang đến trải nghiệm cà phê dễ tiếp cận nhưng vẫn giữ chiều sâu hương vị. Từ lựa chọn nguyên liệu đến cách phục vụ, chúng tôi ưu tiên sự ổn định, sạch sẽ và thân thiện với khách địa phương lẫn khách ghé thăm Gành Hào.</p>
  </section>

  <section class="space-y-4">
    <h2 class="font-bebas text-xl tracking-[0.2em] text-luxury-accent uppercase">Điều chúng tôi theo đuổi</h2>
    <ul class="space-y-3 text-sm text-luxury-muted/90 leading-7">
      <li>- Hương vị nhất quán cho từng món cà phê và trà.</li>
      <li>- Không gian nhẹ nhàng, phù hợp gặp gỡ và làm việc.</li>
      <li>- Dịch vụ lịch sự, nhanh và rõ ràng.</li>
    </ul>
  </section>
</LuxuryStaticLayout>
