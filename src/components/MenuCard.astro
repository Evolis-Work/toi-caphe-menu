---
import type { MenuItem } from "../types/menu";

interface Props {
  item: MenuItem;
  order: number;
}

const { item, order } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const placeholderSrc = `${baseUrl}placeholder.svg`;
const imageSrc = item.image || placeholderSrc;
---

<article
  class={`menu-card ${item.available ? "" : "is-unavailable"}`}
  data-item
  data-name={item.name}
  data-description={item.description}
  data-price={item.price}
  data-order={order}
  data-available={item.available ? "true" : "false"}
  data-bestseller={item.bestseller ? "true" : "false"}
>
  <img src={imageSrc} alt={item.name} loading="lazy" onerror={`this.onerror=null;this.src='${placeholderSrc}'`} />
  <div class="menu-content">
    <div class="menu-row">
      <h3>{item.name}</h3>
      <strong>{item.price.toLocaleString("vi-VN")}d</strong>
    </div>
    {item.description && <p>{item.description}</p>}
    <div class="badge-row">
      {item.bestseller && <span class="badge badge-hot">Bestseller</span>}
      {!item.available && <span class="badge badge-off">Het mon</span>}
    </div>
  </div>
</article>
