# Public JSON endpoint from Google Sheets.
# Example: https://opensheet.elk.sh/<sheet-id>/<tab-name>
SHEET_JSON_URL=

# Google Sheet edit URL for owner/admin page
# Example: https://docs.google.com/spreadsheets/d/<sheet-id>/edit#gid=0
SHEET_EDIT_URL=

# GitHub Actions workflow page URL (optional)
# Example: https://github.com/<owner>/<repo>/actions/workflows/deploy.yml
WORKFLOW_URL=
