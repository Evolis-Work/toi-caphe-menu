---
import MainLayout from "../layouts/MainLayout.astro";

const strapiAdminUrl = import.meta.env.PUBLIC_STRAPI_ADMIN_URL || "https://your-project.strapiapp.com/admin";
const strapiBaseUrl = import.meta.env.PUBLIC_STRAPI_URL || "https://your-project.strapiapp.com";

const schemaData = [
  { col: "category", example: "Tropical Tea", note: "Tên danh mục hiển thị", badge: "Required" },
  { col: "slug", example: "tropical-tea", note: "Slug URL thân thiện", badge: "Optional" },
  { col: "order", example: "1", note: "Sắp xếp danh mục", badge: "Number" },
  { col: "icon", example: "tea", note: "Tên icon/category mark", badge: "Optional" }
];

const menuItemSchema = [
  { col: "name", example: "Trà Đào", note: "Tên món hiển thị", badge: "Required" },
  { col: "slug", example: "tra-dao", note: "Slug dùng nội bộ", badge: "Optional" },
  { col: "price", example: "25000", note: "Chỉ nhập số (VNĐ)", badge: "Number" },
  { col: "description", example: "Đào thơm mềm, trà thanh mát...", note: "Mô tả ngắn cho menu", badge: "Optional" },
  { col: "temp", example: "cold", note: "hot / cold / both / none", badge: "Enum" },
  { col: "available", example: "true", note: "Còn hàng hay không", badge: "Boolean" },
  { col: "bestseller", example: "false", note: "Món nổi bật", badge: "Boolean" },
  { col: "order", example: "10", note: "Sắp xếp món trong category", badge: "Number" },
  { col: "image", example: "Media upload", note: "Ảnh món trong Media Library", badge: "Media" },
];
---

<MainLayout
  title="Admin Portal | T.Ô.I COFFEE & TEA"
  description="Trang quản trị nội dung menu bằng Strapi Cloud"
  canonicalUrl={Astro.url.href}
  structuredData={undefined}
>
  <Fragment slot="head">
    <meta name="robots" content="noindex,nofollow,noarchive" />
  </Fragment>
  <div class="min-h-screen bg-luxury-bg text-luxury-text font-sans antialiased pb-20">
    <div class="max-w-5xl mx-auto px-6 pt-12 space-y-12">
      <header class="flex flex-col md:flex-row md:items-end justify-between gap-6 border-b border-luxury-border/30 pb-10">
        <div class="space-y-2">
          <div class="flex items-center gap-3">
            <span class="font-bebas text-luxury-accent tracking-[0.3em] text-sm border border-luxury-accent/30 px-2 py-0.5">ADMIN PORTAL</span>
          </div>
          <h1 class="font-bebas text-5xl tracking-tight text-white uppercase">Quản Trị <span class="text-luxury-accent">Strapi</span></h1>
          <p class="font-cormorant italic text-luxury-muted text-lg">Tách frontend và backend rõ ràng. Dữ liệu menu được quản lý trong Strapi Cloud, còn trang chủ chỉ render công khai.</p>
        </div>

        <div class="flex items-center gap-4">
          <div class="text-right hidden md:block">
            <p class="text-[10px] uppercase tracking-widest text-luxury-muted/50">Backend</p>
            <p class="text-xs font-medium text-emerald-500 flex items-center justify-end gap-1.5">
              <span class="size-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
              Strapi Cloud Free
            </p>
          </div>
        </div>
      </header>

      <div class="grid gap-4 md:grid-cols-3">
        {[
          { label: "Category", value: "4 fields", icon: "category" },
          { label: "Menu item", value: "9 fields", icon: "restaurant_menu", color: "text-luxury-accent" },
          { label: "Public API", value: "read-only", icon: "lock" },
        ].map((stat) => (
          <div class="bg-luxury-surface/40 border border-luxury-border/20 p-5 rounded-sm space-y-3">
            <span class={`material-symbols-outlined text-xl ${stat.color ?? "text-luxury-muted"}`}>{stat.icon}</span>
            <div>
              <p class="text-[10px] uppercase tracking-[0.1em] text-luxury-muted/60">{stat.label}</p>
              <p class="text-2xl font-bebas text-white tracking-wider">{stat.value}</p>
            </div>
          </div>
        ))}
      </div>

      <section class="space-y-6">
        <div class="flex items-center gap-4">
          <h2 class="font-bebas text-xl tracking-widest text-white uppercase">Trung Tâm Hành Động</h2>
          <div class="h-[1px] flex-1 bg-luxury-border/10"></div>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          <a href={strapiAdminUrl} target="_blank" rel="noreferrer" class="group relative bg-emerald-950/20 border border-emerald-500/20 p-8 rounded-sm hover:border-emerald-500/50 transition-all duration-500 overflow-hidden">
            <div class="relative z-10 space-y-4">
              <div class="size-12 bg-emerald-500/10 rounded-full flex items-center justify-center text-emerald-500 group-hover:scale-110 transition-transform">
                <span class="material-symbols-outlined">open_in_new</span>
              </div>
              <div>
                <h3 class="font-bebas text-2xl text-white tracking-wide uppercase">Mở Strapi Admin</h3>
                <p class="text-sm text-luxury-muted/80 leading-relaxed mt-2">Quản lý category, món, ảnh, giá, trạng thái và bestseller trong Strapi Cloud.</p>
              </div>
            </div>
            <span class="absolute top-4 right-4 material-symbols-outlined text-emerald-500/30 group-hover:translate-x-1 transition-transform">database</span>
          </a>

          <a href={strapiBaseUrl} target="_blank" rel="noreferrer" class="group relative bg-luxury-accent/5 border border-luxury-accent/20 p-8 rounded-sm hover:border-luxury-accent/50 transition-all duration-500 overflow-hidden">
            <div class="relative z-10 space-y-4">
              <div class="size-12 bg-luxury-accent/10 rounded-full flex items-center justify-center text-luxury-accent group-hover:scale-110 transition-transform">
                <span class="material-symbols-outlined">api</span>
              </div>
              <div>
                <h3 class="font-bebas text-2xl text-white tracking-wide uppercase">Public API URL</h3>
                <p class="text-sm text-luxury-muted/80 leading-relaxed mt-2">Frontend dùng biến môi trường <code class="text-luxury-accent">PUBLIC_STRAPI_URL</code> để lấy dữ liệu menu.</p>
              </div>
            </div>
            <span class="absolute top-4 right-4 material-symbols-outlined text-luxury-accent/30 group-hover:rotate-45 transition-transform">link</span>
          </a>
        </div>
      </section>

      <section class="space-y-8 bg-luxury-surface/20 border border-luxury-border/10 p-8 md:p-10 rounded-sm overflow-hidden">
        <div class="space-y-2">
          <h2 class="font-bebas text-2xl tracking-widest text-white uppercase">Schema đề xuất cho Strapi</h2>
          <p class="font-cormorant italic text-luxury-muted text-sm">Tách thành 2 collection types: `category` và `menu-item`. Frontend sẽ map dữ liệu theo relation category.</p>
        </div>

        <div class="space-y-6">
          <div class="space-y-3">
            <h3 class="font-bebas text-lg tracking-widest text-luxury-accent uppercase">Category</h3>
            <div class="overflow-x-auto luxury-scrollbar pb-2">
              <table class="w-full text-left border-collapse min-w-[900px]">
                <thead>
                  <tr class="border-b border-luxury-border/30 bg-white/[0.02]">
                    {schemaData.map((row) => (
                      <th class="py-4 px-4 font-mono text-[11px] text-luxury-accent uppercase tracking-widest border-r border-luxury-border/10 last:border-0">
                        {row.col}
                        <span class="block text-[8px] font-sans text-luxury-muted/40 mt-1 uppercase font-normal">{row.badge}</span>
                      </th>
                    ))}
                  </tr>
                </thead>
                <tbody class="text-[13px]">
                  <tr class="border-b border-luxury-border/10">
                    {schemaData.map((row) => (
                      <td class="py-6 px-4 text-luxury-muted border-r border-luxury-border/10 last:border-0 align-top">
                        <p class="text-white mb-2 font-medium">{row.example}</p>
                        <p class="text-[11px] text-luxury-muted/60 leading-relaxed italic">{row.note}</p>
                      </td>
                    ))}
                  </tr>
                </tbody>
              </table>
            </div>
          </div>

          <div class="space-y-3">
            <h3 class="font-bebas text-lg tracking-widest text-luxury-accent uppercase">Menu item</h3>
            <div class="overflow-x-auto luxury-scrollbar pb-2">
              <table class="w-full text-left border-collapse min-w-[1100px]">
                <thead>
                  <tr class="border-b border-luxury-border/30 bg-white/[0.02]">
                    {menuItemSchema.map((row) => (
                      <th class="py-4 px-4 font-mono text-[11px] text-luxury-accent uppercase tracking-widest border-r border-luxury-border/10 last:border-0">
                        {row.col}
                        <span class="block text-[8px] font-sans text-luxury-muted/40 mt-1 uppercase font-normal">{row.badge}</span>
                      </th>
                    ))}
                  </tr>
                </thead>
                <tbody class="text-[13px]">
                  <tr class="border-b border-luxury-border/10">
                    {menuItemSchema.map((row) => (
                      <td class="py-6 px-4 text-luxury-muted border-r border-luxury-border/10 last:border-0 align-top">
                        <p class="text-white mb-2 font-medium">{row.example}</p>
                        <p class="text-[11px] text-luxury-muted/60 leading-relaxed italic">{row.note}</p>
                      </td>
                    ))}
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </section>

      <section class="space-y-10 py-10">
        <div class="text-center space-y-2">
          <h2 class="font-bebas text-2xl tracking-[0.3em] text-white uppercase">Quy Trình Cập Nhật</h2>
          <div class="w-12 h-[1px] bg-luxury-accent mx-auto"></div>
        </div>

        <div class="grid md:grid-cols-3 gap-12 relative">
          {[
            { step: "01", title: "Cập Nhật Nội Dung", desc: "Đăng nhập Strapi Admin, sửa category hoặc menu-item, upload ảnh và set trạng thái món." },
            { step: "02", title: "Lưu & Publish", desc: "Lưu dữ liệu, bấm Publish để API public trả về bản mới ngay lập tức." },
            { step: "03", title: "Frontend Tự Đọc", desc: "Trang menu của khách fetch API Strapi trực tiếp, không cần sheet hay rebuild thủ công." },
          ].map((item) => (
            <div class="relative space-y-4 group">
              <span class="font-bebas text-6xl text-luxury-border/30 group-hover:text-luxury-accent/10 transition-colors duration-700 absolute -top-8 -left-2 select-none z-0">{item.step}</span>
              <div class="relative z-10 space-y-2 pt-2">
                <h3 class="font-bebas text-xl text-luxury-accent tracking-wide uppercase">{item.title}</h3>
                <p class="text-sm text-luxury-muted/80 leading-relaxed font-sans">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <footer class="pt-20 text-center space-y-4 border-t border-luxury-border/10">
        <p class="font-bebas text-xs tracking-[0.4em] text-luxury-muted/40 uppercase">© 2026 T.Ô.I COFFEE & TEA • STRAPI MANAGEMENT SYSTEM</p>
        <a href="/" class="inline-flex items-center gap-2 text-luxury-accent hover:gap-3 transition-all text-xs uppercase tracking-widest">
          <span class="material-symbols-outlined text-sm">arrow_back</span>
          Quay lại Menu chính
        </a>
      </footer>
    </div>
  </div>
</MainLayout>
