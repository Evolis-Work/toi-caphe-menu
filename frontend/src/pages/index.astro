---
import LuxuryHomePage from "../components/home-page/LuxuryHomePage";
import { fetchMenu } from "../lib/fetchMenu";
import "../styles/global.css";

const baseUrl = import.meta.env.BASE_URL;
const withBase = (path: string): string => `${baseUrl.replace(/\/?$/, "/")}${path.replace(/^\//, "")}`;
const faviconUrl = withBase("favicon.svg");
const ogImageUrl = withBase("og-menu.svg");
const heroPreloadUrl = withBase("placeholder.svg");

const siteUrl = Astro.site?.toString() ?? "https://evolis-work.github.io";
const canonicalUrl = new URL(withBase(""), siteUrl).toString();
const ogImageAbsoluteUrl = new URL(ogImageUrl, siteUrl).toString();
const mapUrl = "https://maps.app.goo.gl/aKEMj32fUoLTsR9s8";
const businessTelephone = import.meta.env.PUBLIC_BUSINESS_TELEPHONE ?? import.meta.env.BUSINESS_TELEPHONE ?? "+84848882852";
const businessPostalCode = import.meta.env.PUBLIC_BUSINESS_POSTAL_CODE ?? import.meta.env.BUSINESS_POSTAL_CODE ?? "97600";
const businessPriceRange = import.meta.env.PUBLIC_BUSINESS_PRICE_RANGE ?? "$";
const keywords = [
  "Lộc Cà Phê",
  "Loc Ca Phe",
  "quán cà phê gành hào",
  "cà phê gành hào",
  "loc ca phe",
  "quán cà phê bạc liêu",
  "cafe đông hải bạc liêu",
].join(", ");

const structuredData = {
  "@context": "https://schema.org",
  "@type": "CafeOrCoffeeShop",
  name: "Lộc Cà Phê",
  alternateName: ["Loc Ca Phe", "Lộc Cafe", "loc ca phe"],
  url: canonicalUrl,
  image: ogImageAbsoluteUrl,
  hasMap: mapUrl,
  sameAs: [mapUrl],
  address: {
    "@type": "PostalAddress",
    streetAddress: "2CJC+V6R, Ấp 4, Đông Hải",
    addressLocality: "Bạc Liêu",
    ...(businessPostalCode ? { postalCode: businessPostalCode } : {}),
    addressCountry: "VN",
  },
  servesCuisine: "Coffee, Tea",
  priceRange: businessPriceRange,
  ...(businessTelephone ? { telephone: businessTelephone } : {}),
};

const categories = await fetchMenu();
---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />

    <title>Lộc Cà Phê | Quán Cà Phê Gành Hào, Bạc Liêu</title>
    <meta
      name="description"
      content="Lộc Cà Phê - quán cà phê tại Gành Hào, Bạc Liêu. Khám phá menu cà phê, trà và tìm đường đến 2CJC+V6R, Ấp 4, Đông Hải."
    />
    <meta name="keywords" content={keywords} />
    <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="vi_VN" />
    <meta property="og:site_name" content="Lộc Cà Phê" />
    <meta property="og:title" content="Lộc Cà Phê | Quán Cà Phê Gành Hào, Bạc Liêu" />
    <meta
      property="og:description"
      content="Thưởng thức cà phê và trà tại Lộc Cà Phê. Địa chỉ: 2CJC+V6R, Ấp 4, Đông Hải, Bạc Liêu."
    />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageAbsoluteUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Lộc Cà Phê | Quán Cà Phê Gành Hào, Bạc Liêu" />
    <meta
      name="twitter:description"
      content="Menu Lộc Cà Phê - quán cà phê Gành Hào, Bạc Liêu."
    />
    <meta name="twitter:image" content={ogImageAbsoluteUrl} />

    <meta name="theme-color" content="#0d0d0d" />
    <link rel="icon" href={faviconUrl} type="image/svg+xml" />
    <link rel="preload" as="image" href={heroPreloadUrl} />

    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap"
      media="print" onload="this.media='all'" rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=block"
      media="print" onload="this.media='all'" rel="stylesheet"
    />
  </head>
  <body class="min-h-screen flex flex-col overflow-x-hidden">
    <LuxuryHomePage categories={categories} baseUrl={baseUrl} client:load />
  </body>
</html>
